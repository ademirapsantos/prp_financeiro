# PostgreSQL (container interno, sem exposicao de porta no host)
POSTGRES_DB_PROD=CHANGE_ME_DB
POSTGRES_USER_PROD=CHANGE_ME_USER
POSTGRES_PASSWORD_PROD=CHANGE_ME_STRONG_PASSWORD

# URL de conexao usada pelo app/updater
DATABASE_URL_PROD=postgresql://CHANGE_ME_USER:CHANGE_ME_STRONG_PASSWORD@prp-postgres-prod:5432/CHANGE_ME_DB

# Seguranca da aplicacao
SECRET_KEY=CHANGE_ME_SECRET_KEY
UPDATE_TOKEN=CHANGE_ME_UPDATE_TOKEN

# Imagens de producao (GHCR)
PRP_IMAGE_PROD=ghcr.io/ademirapsantos/prp_financeiro:prod-latest
UPDATER_IMAGE_PROD=ghcr.io/ademirapsantos/prp_financeiro_updater:prod-latest
