# Nome do projeto compose para o ambiente de producao
COMPOSE_PROJECT_NAME_PROD=prp

# PostgreSQL (container interno, sem exposicao de porta no host)
POSTGRES_DB_PROD=prp_financeiro
POSTGRES_USER_PROD=prp_user
POSTGRES_PASSWORD_PROD=zH23LJGicTj9SR
PG_BIN_DIR=/usr/local/bin
# URL de conexao usada pelo app/updater
DATABASE_URL_PROD=postgresql://prp_user:zH23LJGicTj9SR@prp-postgres-prod:5432/prp_financeiro

# Binarios PostgreSQL para backup/restore (opcional)
# Preferencialmente configure apenas PG_BIN_DIR para padronizar.
PG_BIN_DIR=/usr/local/bin
# PG_DUMP_BIN=/usr/local/bin/pg_dump
# PG_RESTORE_BIN=/usr/local/bin/pg_restore

# Update com migracao de banco (opcional)
# Pode ser sobrescrito por "requires_db_migration" no manifesto da release.
REQUIRES_DB_MIGRATION=false
# Comando executado no container da app para validar/aplicar migracao.
# Se vazio, updater usa comando padrao interno.
DB_MIGRATION_CMD=
DB_MIGRATION_TIMEOUT_SECONDS=300

# Seguranca da aplicacao
SECRET_KEY=b4e70565704647f38dd1b0c8c10b899c4f7dfc14b82d0d3b55a29471de767eb1
UPDATE_TOKEN=b46f85ba3d6b38ee9322aa6580960dbec6abda3d3d20c60f96ab86fc48443ba2

# Imagens de producao (GHCR)
PRP_IMAGE_PROD=ghcr.io/ademirapsantos/prp_financeiro:prod-latest
UPDATER_IMAGE_PROD=ghcr.io/ademirapsantos/prp_financeiro_updater:prod-latest
